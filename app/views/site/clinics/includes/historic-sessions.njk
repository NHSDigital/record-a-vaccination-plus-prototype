{% set legacySessionHistory = legacySessionHistory or [] %}

{% if (legacySessionHistory | length) > 0 %}
  <h2 class="nhsuk-heading-m">Clinics created before 14 August 2026</h2>
  <div class="nhsuk-grid-row">
    <div class="nhsuk-grid-column-two-thirds">
      <p>These clinics are listed separately because of recent improvements we have made to the service. You can view, change and cancel them individually.</p>
      <p><a href="#">You can read our guidance on why these are different and how to manage clinics (opens in a new tab)</a></p>
    </div>
  </div>
  <table class="nhsuk-table">
    <thead class="nhsuk-table__head">
      <tr class="nhsuk-table__row">
        <th scope="col" class="nhsuk-table__header">Time</th>
        <th scope="col" class="nhsuk-table__header">Services</th>
        <th scope="col" class="nhsuk-table__header">Booked</th>
        <th scope="col" class="nhsuk-table__header">Free</th>
        <th scope="col" class="nhsuk-table__header">Actions</th>
      </tr>
    </thead>
    <tbody class="nhsuk-table__body">
      {% for session in legacySessionHistory %}
        <tr class="nhsuk-table__row">
          <td class="nhsuk-table__cell">
            <div>{{ session.date | formatDate('EEEE d MMMM yyyy') }}</div>
            <strong>{{ session.from | nhsTime }} to {{ session.until | nhsTime }}</strong>
          </td>
          <td class="nhsuk-table__cell">
            {% for serviceId in session.services %}
              {{ data.services[serviceId].name if data.services[serviceId] else serviceId }}{% if not loop.last %}<br>{% endif %}
            {% endfor %}
          </td>
          <td class="nhsuk-table__cell">
            {% for serviceId in session.services %}
              {% set bookedForService = session.bookedByService[serviceId] if session.bookedByService and (session.bookedByService[serviceId] is defined) else (session.bookedTotal or 0) %}
              {{ bookedForService }} booked{% if not loop.last %}<br>{% endif %}
            {% endfor %}
          </td>
          <td class="nhsuk-table__cell">{{ session.unbookedTotal or 0 }} free</td>
          <td class="nhsuk-table__cell">
            <ul class="nhsuk-list nhsuk-u-margin-bottom-0">
              <li>
                <a href="/site/{{ site_id }}/clinics/edit/{{ session.id }}">
                  View and change
                  <span class="nhsuk-u-visually-hidden"> clinic on {{ session.date | formatDate('EEEE d LLLL yyyy') }} at {{ session.from | nhsTime }} to {{ session.until | nhsTime }}</span>
                </a>
              </li>
              <li>
                <a href="/site/{{ site_id }}/clinics/cancel/{{ session.id }}">
                  Cancel
                  <span class="nhsuk-u-visually-hidden"> clinic on {{ session.date | formatDate('EEEE d LLLL yyyy') }} at {{ session.from | nhsTime }} to {{ session.until | nhsTime }}</span>
                </a>
              </li>
            </ul>
          </td>
        </tr>
      {% endfor %}
    </tbody>
  </table>
{% endif %}
